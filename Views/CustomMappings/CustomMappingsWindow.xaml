<Window x:Class="KannadaNudiEditor.Views.CustomMappings.CustomMappingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Custom Conversion Mappings"
        WindowStartupLocation="CenterOwner"
        Width="750"
        Height="650"
        ShowInTaskbar="False"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title and Description -->
        <StackPanel Grid.Row="0"
                Margin="20"
                Background="#F5F5F5">
            <TextBlock Text="Custom Conversion Mappings"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>
            <TextBlock Text="Add custom character mappings for ASCII to Unicode conversion. Enter individual characters or short sequences in both columns."
                       TextWrapping="Wrap"
                       FontSize="12"
                       Foreground="Gray"/>
        </StackPanel>

        <!-- Mappings List with DataGrid-like structure -->
        <Grid Grid.Row="1"
                Margin="20,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Column Headers -->
            <Grid Grid.Row="0"
                    Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="ASCII Character/Sequence"
                           FontWeight="Bold"
                           FontSize="12"
                           Margin="5,0"/>

                <TextBlock Grid.Column="2"
                           Text="Unicode Character/Sequence"
                           FontWeight="Bold"
                           FontSize="12"
                           Margin="5,0"/>

                <TextBlock Grid.Column="3"
                           Text="Action"
                           FontWeight="Bold"
                           FontSize="12"
                           Margin="5,0"
                           HorizontalAlignment="Center"/>
            </Grid>

            <!-- Scrollable Mappings Container -->
            <ScrollViewer Grid.Row="1"
                    VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="mappingsContainer"
                            Orientation="Vertical"/>
            </ScrollViewer>
        </Grid>

        <!-- Status/Info Section -->
        <TextBlock Grid.Row="2"
                   x:Name="statusTextBlock"
                   Margin="20"
                   FontSize="12"
                   Foreground="Gray"
                   Text="Total mappings: 0"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="20">
            <Button Width="100"
                    Height="40"
                    Margin="5,0"
                    Content="➕ Add Row"
                    Click="AddMapping_Click"
                    Background="#4CAF50"
                    Foreground="White"
                    FontWeight="Bold"/>
            <Button Width="100"
                    Height="40"
                    Margin="5,0"
                    Content="Save"
                    Click="Save_Click"
                    Background="#2196F3"
                    Foreground="White"
                    FontWeight="Bold"/>
            <Button Width="100"
                    Height="40"
                    Margin="5,0"
                    Content="Cancel"
                    Click="Cancel_Click"
                    Background="#757575"
                    Foreground="White"
                    FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
