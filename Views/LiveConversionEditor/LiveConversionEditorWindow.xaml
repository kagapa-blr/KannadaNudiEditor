<Window x:Class="KannadaNudiEditor.Views.LiveConversionEditor.LiveConversionEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Kannada Conversion - ASCII ↔ Unicode"
        WindowStartupLocation="CenterScreen"
        Width="1100"
        Height="700"
        MinWidth="800"
        MinHeight="600"
        ShowInTaskbar="True"
        WindowStyle="ThreeDBorderWindow"
        ResizeMode="CanResizeWithGrip"
        Background="White"
        Loaded="Window_Loaded">

        <Window.Resources>
                <Style x:Key="SimpleButton"
                                TargetType="Button">
                        <Setter Property="Padding"
                                        Value="8,5"/>
                        <Setter Property="FontSize"
                                        Value="12"/>
                        <Setter Property="Cursor"
                                        Value="Hand"/>
                        <Setter Property="Background"
                                        Value="White"/>
                        <Setter Property="BorderBrush"
                                        Value="#CCC"/>
                        <Setter Property="BorderThickness"
                                        Value="1"/>
                </Style>
        </Window.Resources>

        <DockPanel>
                <!-- Top Toolbar -->
                <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Margin="5,3"
                                Height="28">
                        <TextBlock Text="Mode:"
                                        VerticalAlignment="Center"
                                        Margin="0,0,5,0"
                                        FontWeight="Bold"
                                        FontSize="11"/>
                        <ToggleButton x:Name="ModeToggle"
                                        Checked="ModeToggle_Checked"
                                        Unchecked="ModeToggle_Unchecked"
                                      Padding="8,3"
                                        MinWidth="110"
                                        VerticalAlignment="Center"
                                        FontSize="11">
                                <TextBlock x:Name="ModeLabel"
                                                Text="ASCII → Unicode"
                                                TextAlignment="Center"/>
                        </ToggleButton>

                        <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                                        Margin="6,0"/>

                        <Button Content="◄ Copy"
                                        Click="CopyLeft_Click"
                                        Style="{StaticResource SimpleButton}"
                                        Margin="0,0,3,0"
                                        ToolTip="Copy left"
                                        Padding="6,3"
                                        FontSize="11"/>
                        <Button Content="► Copy"
                                        Click="CopyRight_Click"
                                        Style="{StaticResource SimpleButton}"
                                        Margin="0,0,4,0"
                                        ToolTip="Copy right"
                                        Padding="6,3"
                                        FontSize="11"/>

                        <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                                        Margin="6,0"/>

                        <Button Content="− Zoom"
                                        Click="ZoomOut_Click"
                                        Style="{StaticResource SimpleButton}"
                                        Margin="0,0,3,0"
                                        Padding="6,3"
                                        FontSize="11"/>
                        <TextBlock x:Name="ZoomDisplayLabel"
                                        Text="100%"
                                        VerticalAlignment="Center"
                                        Margin="2,0"
                                        FontWeight="Bold"
                                        MinWidth="28"
                                        TextAlignment="Center"
                                        FontSize="11"/>
                        <Button Content="+ Zoom"
                                        Click="ZoomIn_Click"
                                        Style="{StaticResource SimpleButton}"
                                        Margin="2,0,4,0"
                                        Padding="6,3"
                                        FontSize="11"/>

                        <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                                        Margin="6,0"/>

                        <Button Content="↔ Swap"
                                        Click="Swap_Click"
                                        Style="{StaticResource SimpleButton}"
                                        Margin="0,0,3,0"
                                        ToolTip="Swap"
                                        Padding="6,3"
                                        FontSize="11"/>
                        <Button Content="✕ Clear"
                                        Click="ClearAll_Click"
                                        Style="{StaticResource SimpleButton}"
                                        ToolTip="Clear"
                                        Padding="6,3"
                                        FontSize="11"/>
                </StackPanel>

                <!-- Status/Message Bar (just below buttons) -->
                <Border DockPanel.Dock="Top"
                                Background="#F5F5F5"
                                BorderBrush="#DDD"
                                BorderThickness="0,0,0,1"
                                Padding="6,3">
                        <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="StatusTextBlock"
                                                Text="Ready"
                                                FontSize="10"
                                                VerticalAlignment="Center"/>
                                <TextBlock Text=" | "
                                                Margin="5,0"
                                                VerticalAlignment="Center"
                                                Foreground="#999"
                                                FontSize="9"/>
                                <TextBlock x:Name="CharCountTextBlock"
                                                Text="0 characters"
                                                FontSize="10"
                                                VerticalAlignment="Center"/>
                                <TextBlock x:Name="ConversionTimeTextBlock"
                                                Text=""
                                                FontSize="9"
                                                Foreground="#999"
                                                Margin="5,0,0,0"
                                                VerticalAlignment="Center"/>
                        </StackPanel>
                </Border>

                <!-- Main Content (fills remaining space) -->
                <Grid>
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left Panel -->
                        <DockPanel Grid.Column="0"
                                        Margin="2">
                                <Border DockPanel.Dock="Top"
                                                Background="#0078D4"
                                                Padding="6,3"
                                                TextBlock.Foreground="White">
                                        <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="LeftPanelTitle"
                                                                Text="ASCII Input"
                                                                FontWeight="Bold"
                                                                FontSize="11"/>
                                                <TextBlock x:Name="LeftCharCount"
                                                                Text=""
                                                                Margin="5,0,0,0"
                                                                Opacity="0.8"
                                                                FontSize="9"/>
                                        </StackPanel>
                                </Border>
                                <RichTextBox x:Name="LeftTextBox"
                                                Padding="6"
                                                FontFamily="Consolas"
                                                FontSize="11"/>
                        </DockPanel>

                        <!-- Separator -->
                        <Border Grid.Column="1"
                                        Background="#DDD"/>

                        <!-- Right Panel -->
                        <DockPanel Grid.Column="2"
                                        Margin="2">
                                <Border DockPanel.Dock="Top"
                                                Background="#107C10"
                                                Padding="6,3"
                                                TextBlock.Foreground="White">
                                        <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="RightPanelTitle"
                                                                Text="Unicode Output"
                                                                FontWeight="Bold"
                                                                FontSize="11"/>
                                                <TextBlock x:Name="RightCharCount"
                                                                Text=""
                                                                Margin="5,0,0,0"
                                                                Opacity="0.8"
                                                                FontSize="9"/>
                                        </StackPanel>
                                </Border>
                                <RichTextBox x:Name="RightTextBox"
                                                Padding="6"
                                                FontFamily="NudiParijatha"
                                                FontSize="12"/>
                        </DockPanel>
                </Grid>
        </DockPanel>
</Window>
